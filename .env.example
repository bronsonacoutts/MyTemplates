# Environment Variables Example
# Copy this file to .env and fill in the values

# =============================================================================
# CLIENT-SIDE VARIABLES (Prefixed with VITE_ - exposed to browser)
# =============================================================================
# These are safe to expose to the client - DO NOT put secrets here
VITE_APP_NAME=MyTemplates
VITE_API_URL=http://localhost:3000/api
VITE_ENABLE_ANALYTICS=false

# =============================================================================
# SERVER-SIDE VARIABLES (NO VITE_ prefix - server only)
# =============================================================================
# These are NEVER exposed to the client - secrets should go here
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
API_SECRET_KEY=your-secret-key-here
AUTH_TOKEN=your-auth-token

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================
NODE_ENV=development

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# Add your third-party service credentials here
# Examples:
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# =============================================================================
# NOTES
# =============================================================================
# 1. NEVER commit .env files to git
# 2. Use VITE_ prefix ONLY for non-sensitive client-side config
# 3. Server secrets MUST NOT have VITE_ prefix
# 4. For production: Use 1Password/Vercel/Azure Key Vault
# 5. For local development: Copy this to .env and customize
