name: PR Validation

on:
  pull_request:
    types:
      - opened
      - edited
      - synchronize
      - reopened

jobs:
  validate-pr-title:
    name: Validate PR Title
    runs-on: ubuntu-latest
    permissions: {}
    steps:
      - name: Check PR title follows Conventional Commits
        uses: amannn/action-semantic-pull-request@v5
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          types: |
            feat
            fix
            docs
            style
            refactor
            perf
            test
            build
            ci
            chore
            revert
          requireScope: false
          subjectPattern: ^(?![A-Z]).+$
          subjectPatternError: |
            The subject "{subject}" found in the PR title "{title}" is invalid.
            The subject must begin with a lowercase letter.

  validate-branch-name:
    name: Validate Branch Name
    runs-on: ubuntu-latest
    permissions: {}
    steps:
      - name: Check branch name follows allowed patterns
        run: |
          BRANCH="${{ github.head_ref }}"
          echo "Validating branch name: $BRANCH"

          PATTERN="^(feature|fix|hotfix|release|docs|refactor|test|chore|copilot|codex)\/[a-z0-9][a-z0-9\-]*[a-z0-9]$"

          if [[ "$BRANCH" =~ $PATTERN ]]; then
            echo "✅ Branch name '$BRANCH' is valid."
          else
            echo "❌ Branch name '$BRANCH' does not match the required pattern."
            echo ""
            echo "Branch names must follow the pattern: <prefix>/<description>"
          echo "Allowed prefixes: feature, fix, hotfix, release, docs, refactor, test, chore, copilot, codex"
          echo "Description must be lowercase kebab-case (e.g., feature/add-user-auth)"
          exit 1
          fi
