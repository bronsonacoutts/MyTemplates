#!/usr/bin/env sh

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if [ -x "$repo_root/node_modules/.bin/commitlint" ]; then
  cd "$repo_root" || exit 1
  node scripts/local-validation-signal.js attach "$1"
  npx --no -- commitlint --edit "$1"
else
  echo "Skipping commit-msg: commitlint is not installed. Run npm install." >&2
fi
