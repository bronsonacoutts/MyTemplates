#!/usr/bin/env sh

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if [ -x "$repo_root/node_modules/.bin/lint-staged" ]; then
  cd "$repo_root" || exit 1
  node scripts/local-validation-signal.js clear
  npx lint-staged
  npm run validate:local
  node scripts/local-validation-signal.js mark "lint,format:check,validate:catalog,type-check,test"
else
  echo "Skipping pre-commit: lint-staged is not installed. Run npm install." >&2
fi
