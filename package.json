{
  "name": "my-templates",
  "version": "1.0.0",
  "description": "Template and starter scaffolds with comprehensive guardrails",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "ci:checks": "npm run lint && npm run format:check && npm run validate:catalog && npm run type-check",
    "ci:tests": "npm test",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "build": "tsc && vite build",
    "validate:branch": "node scripts/validate-branch.js",
    "validate:catalog": "node scripts/validate-template-metadata.js",
    "validate:release-notes": "node scripts/validate-release-notes.js",
    "validate": "npm run ci:checks && npm run ci:tests",
    "validate:local": "npm run ci:checks && npm run ci:tests",
    "sync-instructions": "node scripts/sync-instructions.js",
    "sync-pack": "node scripts/sync-pack.js",
    "detect-drift": "node scripts/detect-drift.js",
    "prepare": "husky install && node scripts/sync-instructions.js",
    "pre-commit": "lint-staged",
    "sendit": "node scripts/sendit.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
